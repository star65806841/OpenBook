#!/usr/bin/env python3

import sys

def error(str):
    print("\033[1;31m" + str + "\033[0m")

def warning(str):
    print("\033[1;33m" + str + "\033[0m")

def info(str):
    print("\033[1;0m" + str + "\033[0m")

def finish(str):
    print("\033[1;32m" + str + "\033[0m")

def errorExit(str,code):
    error(str)
    sys.exit(code)

def copyInfo(src,dst):
    info("copy %(src)s to %(dst)s" % {"src":src,"dst":dst})

# 跳过判断时的信息
# flag:true输出错误，false则输出警告
def skipinfo(flag,
             str,
             exitcode):
    if flag:
        errorExit(str,exitcode)
    else:
        warning(str)
    None