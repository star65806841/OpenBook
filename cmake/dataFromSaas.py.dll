#!/usr/bin/env python3

import os
import requests
import json
from urllib.parse import urlparse, unquote

class SaasData:
    def get_printers_details(self, device, detail_file, saas_server):
        # API URL
        url = f"https://{saas_server}/lifemaster/api/product/queryProductWithQt"
        
        # 请求头参数
        headers = {
            "device": device,
            "lang": "zh-CN",
            "ua": "S-1-5-21-2035418733-927691529-4190326716-19607",
            "versionCode": "5.2.0.0000",
            "versionName": "Labelife"
        }    
        
        try:
            # 发送GET请求（如果是POST，使用requests.post）
            print(f"正在发送请求到: {url}")
            response = requests.get(url, headers=headers, timeout=30)
            
            # 检查响应状态
            response.raise_for_status()  # 如果状态码不是200，抛出异常
            
            # 获取响应内容
            result = response.text
            print(f"请求成功! 状态码: {response.status_code}")
            print(f"响应内容长度: {len(result)} 字符")        
            
            # 先尝试解析为JSON，确保格式正确
            try:
                json_data = response.json()  # 直接解析为JSON对象
                # 保存到文件
                with open(detail_file, 'w', encoding='utf-8') as f:                        
                    json.dump(json_data['data'], f, ensure_ascii=False, indent=2)
                print(f"JSON数据已保存到: {detail_file}")            
            except json.JSONDecodeError:
                # 如果响应不是JSON，保存为文本
                print("响应不是有效的JSON格式，保存为文本文件")
                with open(detail_file, 'w', encoding='utf-8') as f:
                    f.write(result)
                print(f"响应文本已保存到: {detail_file}")            
            return True
            
        except requests.exceptions.RequestException as e:
            print(f"请求失败: {e}")
            return None
        except Exception as e:
            print(f"发生错误: {e}")
            return False

    def get_ext_from_url(self, icon_url: str, default=".png"):
        parsed = urlparse(icon_url)
        path = unquote(parsed.path)        # 解码中文
        _, ext = os.path.splitext(path)    # 拆分后缀
        return ext if ext else default

    def download_printer_thumbnail(self, detail_file):        
        # ---------- 读取 JSON ----------
        with open(detail_file, "r", encoding="utf-8") as f:
            json_data = json.load(f)
            
        for item in json_data:    
            device_types = item.get("deviceTypes")
            if not device_types:
                continue

            icon_url = device_types.get("iconUrl")
            if not icon_url:
                continue

            id = device_types.get("id")
            if not id:
                continue
            
            # 解析文件名
            parsed_url = urlparse(icon_url)
            filename = os.path.basename(parsed_url.path)
            local_path = f"{os.getcwd()}/pkg_common_resource/Config/AimoDetails/PrinterImages"

            # 保存文件
            local_path_file = os.path.join(local_path, id + self.get_ext_from_url(icon_url))

            # 下载文件
            try:
                response = requests.get(icon_url, timeout=10)
                response.raise_for_status()

                with open(local_path_file, "wb") as img_file:
                    img_file.write(response.content)

                # 新增 iconLocal 节点
                device_types["iconLocal"] = os.path.abspath(local_path_file)

                print(f"下载成功: {icon_url} -> {local_path_file}")

            except Exception as e:
                print(f"下载失败: {icon_url}, 错误: {e}")
                device_types["iconLocal"] = None

        # ---------- 保存新的 JSON ----------
        with open(detail_file, "w", encoding="utf-8") as f:
            json.dump(json_data, f, ensure_ascii=False, indent=4)

        print("处理完成，已保存:", detail_file)    
                        
    def update(self, device, saas_server):
        # 保存到JSON文件        
        detail_file = f"{os.getcwd()}/pkg_common_resource/Config/AimoDetails/PrinterDetails"
        # 1. 从Saas获取打印机详情
        if(self.get_printers_details(device, detail_file, saas_server) == False):
            return False
        # 2. 下载打印机缩略图并更新路径到PrinterDetails
        self.download_printer_thumbnail(detail_file)