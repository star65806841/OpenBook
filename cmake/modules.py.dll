    def verify_sign(self, path):        
        #cprint.info(f"开始验证签名完整性->{path}")
        self.run_cmd(f'codesign -v "{path}"')
        #self.run_cmd(f'codesign --verify --deep --strict --verbose=4 "{path}"')        

    def run_cmd(self, cmd):
        cprint.info(f"运行命令->{cmd}")
        os.system(cmd)

    def run_sign_exe(self, sign_exe, need_sign_dir, signed_dir):
        cprint.info(f'运行签名程序: {sign_exe} {need_sign_dir} {signed_dir}')
        os.system(f'{sign_exe} {need_sign_dir} {signed_dir}')
        
    def signDlls(self, signExe, output_path):
        need_sign_files = os.path.join(output_path,'need_sign_files')
        if os.path.exists(need_sign_files):
            self.deleteDir(need_sign_files)
        
        os.mkdir(need_sign_files)
        
        labelife = os.path.join(output_path,'Labelife')
        self.copyDir(os.path.join(output_path,'bin'), need_sign_files)
        self.copyFile(os.path.join(output_path,'AimoUI', 'aimoquickcontrolplugin.dll'), os.path.join(need_sign_files, 'aimoquickcontrolplugin.dll'))
        self.copyFile(os.path.join(labelife, '7z.exe'), os.path.join(need_sign_files, '7z.exe'))
        self.copyFile(os.path.join(labelife, '7z.dll'), os.path.join(need_sign_files, '7z.dll'))
        self.copyFile(os.path.join(labelife, 'parfait.dll'), os.path.join(need_sign_files, 'parfait.dll'))
        self.copyFile(os.path.join(labelife, 'parfait_crash_handler.exe'), os.path.join(need_sign_files, 'parfait_crash_handler.exe'))
        self.copyFile(os.path.join(labelife, 'uninst.exe'), os.path.join(need_sign_files, 'uninst.exe'))
        
        cprint.info(f"待签名目录{need_sign_files} -> 完成目录：{labelife}")
        self.run_sign_exe(signExe, os.path.join(output_path,'need_sign_files'), os.path.join(output_path,'Labelife'))
        
        self.copyFile(os.path.join(labelife, 'aimoquickcontrolplugin.dll'), os.path.join(labelife, 'qml', 'AimoUI', 'aimoquickcontrolplugin.dll'))
        os.remove(os.path.join(labelife, 'aimoquickcontrolplugin.dll'))
        
    def signSetupExe(self, signExe, output_path, exe_file):
        need_sign_exe_dir = os.path.join(output_path,'need_sign_exe')
        #清空原有旧文件
        if os.path.exists(need_sign_exe_dir):
            self.deleteDir(need_sign_exe_dir)
        
        os.mkdir(need_sign_exe_dir)
        
        self.copyFile(os.path.join(output_path, exe_file), os.path.join(need_sign_exe_dir, exe_file))
        os.remove(os.path.join(output_path, exe_file))
        
        cprint.info(f"待签名目录{need_sign_exe_dir} -> 完成目录：{output_path}")        
        self.run_sign_exe(signExe, need_sign_exe_dir, output_path)            