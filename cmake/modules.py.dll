        cprint.info('开始签名 -> ' + dmg)

        cmd = 'codesign --force --verify --verbose --timestamp --sign "Developer ID Application: ZHUHAI QUYIN TECHNOLOGY CO.,LTD. (J7DJ82QB95)" --options runtime ' + dmg
        self.run_cmd(cmd)

        self.verify_sign(dmg)        
    
        cprint.info('开始认证DMG -> ' + dmg)
        self.run_cmd(f'xcrun notarytool submit {dmg} --apple-id "yingqi_t@aimotech.cn" --password "ijhe-oevu-gdma-lrca" --team-id "J7DJ82QB95" --wait')

        cprint.info('操作完成，请检查认证结果，如果认证失败又无需重新打包编译，可用脚本直接认证之前生成的dmg -> ' + dmg)
        
