#!/usr/bin/env python3
import platform
from enum import Enum

class SystemType(Enum):
    Unknown = -1
    Win     = 0
    Linux   = 1
    Mac     = 2

    #获取系统类型
    @staticmethod
    def getSystem():
        system = platform.system()
        if system == "Linux":
            return SystemType.Linux
        elif system == "MacOs" or system == "Darwin":
            return SystemType.Mac
        elif system == "Windows":
            return SystemType.Win
        else:
            return SystemType.Unknown
    
    @staticmethod
    def isLinux():
        return SystemType.getSystem() == SystemType.Linux
    
    @staticmethod
    def isMac():
        return SystemType.getSystem() == SystemType.Mac

    @staticmethod
    def isWin():
        return SystemType.getSystem() == SystemType.Win

    @staticmethod
    def getArch():
        arch = platform.machine()
        if arch == "x86_64":
            return "amd64"
        
        return arch